# Copy this file to .env in this same directory (packages/server/.env) and
# fill in real values. .env is gitignored; this file is not — keep it in sync
# whenever a new env var is added to the server.

# ── Local MySQL connection (packages/server/config/db.config.ts) ──
# Used only when NODE_ENV is not "production" (see NODE_ENV note below).
# Defaults in db.config.ts if left unset: HOST=localhost, USER=root,
# PASSWORD=root123456, DB_NAME=my-chatbot-schema — set these to match
# whatever local MySQL instance you're running against.
HOST=localhost
USER=root
PASSWORD=root123456
DB_NAME=my-chatbot-schema

# ── JWT signing keys (packages/server/middleware/auth.ts, routes/authRoutes.ts) ──
# Any long random string works for local dev; use distinct values for each.
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# ── AI provider keys (routes/chatRoutes.ts) ──
# Exactly one of these is required, based on EVAL_MODEL below — the chat
# endpoint picks its AI client once at server startup and will fail to boot
# without the matching key set.
# OPENAI_API_KEY — required unless EVAL_MODEL=gemini-2.5-flash (default provider).
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY — required only when EVAL_MODEL=gemini-2.5-flash.
GEMINI_API_KEY=

# Set to "gemini-2.5-flash" to route the chatbot through Google Gemini
# instead of OpenAI. Leave unset (or anything else) to use OpenAI.
EVAL_MODEL=

# ── Runtime ──
# You normally don't need to set this yourself — the "dev" and "start" npm
# scripts already set it to "development"/"production" respectively. It
# controls CORS origin, DB connection target (local vs Railway), and the
# refreshToken cookie's secure/sameSite flags.
NODE_ENV=development

# Port the server listens on. Defaults to 3000 if unset.
PORT=3000

# ── Railway MySQL (production only) ──
# Only read when NODE_ENV=production. Not needed for local development —
# Railway injects these automatically in the deployed environment. Included
# here for reference only.
# MYSQLUSER=
# MYSQL_ROOT_PASSWORD=
# RAILWAY_TCP_PROXY_DOMAIN=
# RAILWAY_TCP_PROXY_PORT=
# MYSQL_DATABASE=
